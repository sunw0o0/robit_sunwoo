#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

void main()
{
	float a, b, c, d, e;
	float max, min;

	printf("1번째 실수를 입력하시오.");
	scanf("%f", &a);

	printf("2번째 실수를 입력하시오.");
	scanf("%f", &b);

	printf("3번째 실수를 입력하시오.");
	scanf("%f", &c);

	printf("4번째 실수를 입력하시오.");
	scanf("%f", &d);

	printf("5번째 실수를 입력하시오.");
	scanf("%f", &e);

	max = a;
	min = a;

	if (b > max) max = b;
	if (c > max) max = c;
	if (d > max) max = d;
	if (e > max) max = e;

	if (b < min) min = b;
	if (c < min) min = c;
	if (d < min) min = d;
	if (e < min) min = e;

	printf("평균은 %f입니다.", (a + b + c + d + e) / 5);
	printf("최댓값은 %f입니다.", max);
	printf("최솟값은 %f입니다.", min);
}
